{
  "name": "voxya-api",
  "version": "1.0.0",
  "main": "dist/src/main",
  "scripts": {
    "test:db:up": "docker-compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker-compose -f docker-compose.test.yml down",
    "test:db:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "test:db:clean": "docker-compose -f docker-compose.test.yml down -v",
    "test": "jest --forceExit --runInBand",
    "test:e2e": "yarn test:db:up && sleep 3 && jest --forceExit --runInBand && yarn test:db:down",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node .",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "yarn typeorm -- migration:generate -d typeorm.config.ts",
    "migration:run": "yarn typeorm -- migration:run -d typeorm.config.ts",
    "migration:revert": "yarn typeorm -- migration:revert -d typeorm.config.ts",
    "migration:run:prod": "typeorm-ts-node-commonjs migration:run -d dist/typeorm.config.js",
    "schema:drop": "yarn typeorm -- schema:drop -d typeorm.config.ts",
    "schema:sync": "yarn typeorm -- schema:sync -d typeorm.config.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/seed.ts",
    "db:seed:prod": "node dist/src/database/seeds/seed.js",
    "db:seed-clear": "ts-node -r tsconfig-paths/register src/database/seeds/seed-clear.ts",
    "db:reset": "ts-node -r tsconfig-paths/register src/database/seeds/reset.ts",
    "db:reset-seed": "ts-node -r tsconfig-paths/register src/database/seeds/index.ts",
    "openapi:export": "ts-node -r tsconfig-paths/register scripts/export-openapi.ts",
    "openapi:generate": "node scripts/generate-clients.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^8.3.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/platform-fastify": "^11.1.9",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/bull": "^3.15.9",
    "@types/jest": "^30.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "csv-parser": "^3.2.0",
    "fastify": "^5.6.2",
    "fastify-multer": "^2.0.3",
    "firebase-admin": "^13.5.0",
    "jest": "^30.2.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.1.4",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.5",
    "typeorm": "^0.3.25",
    "@faker-js/faker": "^10.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.10",
    "@types/passport": "^1.0.17",
    "multer": "^2.0.2",
    "nodemon": "^3.1.10",
    "rxjs": "^7.8.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testTimeout": 30000,
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)": "<rootDir>/$1"
    },
    "coverageDirectory": "../coverage/",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.ts",
      "!main.ts",
      "!bootstrap.ts",
      "!lambda.ts",
      "!config.ts",
      "!**/*.mock.ts",
      "!**/*.service-ext.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 100,
        "statements": 100,
        "branches": 100,
        "functions": 100
      }
    }
  }
}