# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=voxya

# Application Configuration
NODE_ENV=development
PORT=3003

# CORS Configuration
# In production, specify allowed origins separated by commas (e.g., "https://app.example.com,https://www.example.com")
# In development, leave empty to allow all origins
CORS_ORIGINS=

# API Configuration
JWT_PRIVATE_KEY=VOXYA_LOCAL_PRIVATE_KEY
JWT_ACCESS_TOKEN_EXPIRATION_TIME_IN_MILLISECONDS=604800000
ALGORITHM=HS256

# Redis Configuration (optional)
REDIS_HOST=redis
REDIS_PORT=6380

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=voxya_firebase.json